rules_version = '2';

// Dev/trust-mode rules. This CRM currently has no auth, so all reads + writes
// are allowed. When you add Firebase Auth later, tighten these to something
// like: `allow read, write: if request.auth != null;`
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
